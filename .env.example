# PostgreSQL (Docker Compose sets this for the API container)
DATABASE_URL=postgresql://snapshot:snapshot@localhost:5432/market_snapshot

# X (Twitter) API v2 — List tweet sentiment (optional)
# 1) Copy this file to `.env` in the **repo root** (next to docker-compose.yml). That file is gitignored.
# 2) In the X / Twitter developer portal, create a Project → App with OAuth 2.0; use the App’s *Bearer token*
#    (API key type) and a List id from twitter.com → Lists → your list → id from the URL.
# 3) `docker compose` reads the root `.env` automatically. Restart the `api` container after changes.
XBEARER_TOKEN=your_bearer_token_here
X_LIST_ID=your_numeric_list_id

# Databento — US ETF options (SPY / QQQ) PCR from OPRA open interest (prior weekday; optional)
# https://databento.com — dataset defaults to OPRA.PILLAR
# Put keys in this same root `.env` (next to docker-compose.yml). A file in `backend/` alone is not loaded by Compose.
# DATABENTO_API_KEY=
# DATABENTO_DATASET=OPRA.PILLAR

# Scheduler (IST)
SNAPSHOT_CRON_HOUR=16
SNAPSHOT_CRON_MINUTE=0
# Set to 30 or 60 for intraday persistence
INTRADAY_REFRESH_MINUTES=0

# Scheduled / intraday snapshot jobs only (not Admin “full refresh”). Defaults avoid X paid tier (402) and heavy NSE/Databento on every tick.
# Set to 1/true if you want scheduled jobs to call X or option-chain feeds (cost + rate limits apply).
SCHEDULED_SNAPSHOT_INCLUDE_X=0
SCHEDULED_SNAPSHOT_INCLUDE_NSE_OPTIONS=0
SCHEDULED_US_SNAPSHOT_INCLUDE_X=0
SCHEDULED_US_SNAPSHOT_INCLUDE_OPTIONS=0

# If Yahoo returns HTTP 429 (rate limit), increase spacing: default 0.25 seconds between chart GETs
# YAHOO_CHART_MIN_INTERVAL=0.35

# yfinance symbols (optional overrides)
# US snapshot (Dow, NASDAQ, gold, WTI, dollar index) does NOT need any API key — public Yahoo data only.
YFIN_NIFTY_SYMBOL=^NSEI
YFIN_VIX_SYMBOL=^INDIAVIX
YFIN_GIFT_SYMBOL=^NSEI
YFIN_US_INDEX_SYMBOL=^IXIC
YFIN_GOLD_FUTURES=GC=F
YFIN_USD_INR=INR=X
YFIN_CRUDE_SYMBOL=CL=F
YFIN_US_DOW_SYMBOL=^DJI
YFIN_DOLLAR_INDEX_SYMBOL=DX-Y.NYB

# FinBERT downloads on first run; set to speed up cold starts / shrink image behavior
DISABLE_FINBERT=0

# CORS (comma-separated). For HTTPS on your VPS, add your site origin here — compose passes ${API_CORS_ORIGINS}.
API_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
